# Conexion a la base de datos MySQL que corre en Docker (contenedor "empresa").
#
# Formato:  mysql://USUARIO:CONTRASENA@HOST:PUERTO/NOMBRE_DE_LA_BASE
#   USUARIO      = root
#   CONTRASENA   = 12345   (la que definiste con MYSQL_ROOT_PASSWORD)
#   HOST         = localhost   (te conectas desde tu PC al puerto publicado)
#   PUERTO       = 3306        (el que mapeaste con -p 3306:3306)
#   BASE         = empresa_db  (Prisma la crea sola con `prisma db push`)
DATABASE_URL="mysql://root:12345@localhost:3306/empresa_db"
