generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = "5"
  interface            = "sync"
}

datasource db {
  provider = "sqlite"
  url      = "file:./transacciones.db"
}

model Transaccion {
  id      Int    @id @default(autoincrement())
  codigo  String @unique
  tipo    String
  monto   Int
  impacto Float
}
